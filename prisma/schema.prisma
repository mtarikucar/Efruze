// efruze data model — see plan §4
// Run: npx prisma migrate dev --name init  (requires DATABASE_URL in .env)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AWAITING_TRANSFER
  VERIFYING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  BANK_TRANSFER
  PAYTR
}

enum AddressType {
  SHIPPING
  BILLING
}

enum CouponType {
  PERCENT
  FIXED
}

// ============================================================================
// Identity
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  role          UserRole  @default(CUSTOMER)

  customer  Customer?
  admin     Admin?
  addresses Address[]
  orders    Order[]
  carts     Cart[]
  accounts  Account[]
  sessions  Session[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// NextAuth (Auth.js) adapter tables — required by @auth/prisma-adapter.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Customer {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone      String?
  newsletter Boolean @default(false)
}

model Admin {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================================
// Catalog
// ============================================================================

model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  sortOrder Int        @default(0)
  imageUrl  String?
  isActive  Boolean    @default(true)

  translations CategoryTranslation[]
  products     Product[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([slug])
}

model CategoryTranslation {
  id          String   @id @default(cuid())
  categoryId  String
  locale      String
  name        String
  description String?  @db.Text
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
}

model Product {
  id             String    @id @default(cuid())
  slug           String    @unique
  sku            String    @unique
  categoryId     String
  category       Category  @relation(fields: [categoryId], references: [id])
  basePrice      Decimal   @db.Decimal(12, 2)
  currency       String    @default("TRY")
  editionTotal   Int? // null = open edition; integer = "1 of N"
  editionNumber  Int? // for N° displays
  isFeatured     Boolean   @default(false)
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  sortOrder      Int       @default(0)
  seoTitle       String?
  seoDescription String?

  translations ProductTranslation[]
  variants     ProductVariant[]
  images       ProductImage[]
  models3d     ProductModel3D[]
  orderItems   OrderItem[]
  cartItems    CartItem[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([slug])
  @@index([categoryId, isPublished])
  @@index([isFeatured, isPublished])
}

model ProductTranslation {
  id          String  @id @default(cuid())
  productId   String
  locale      String
  name        String
  tagline     String?
  description String? @db.Text
  materials   String? @db.Text
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
}

model ProductVariant {
  id            String      @id @default(cuid())
  productId     String
  sku           String      @unique
  priceOverride Decimal?    @db.Decimal(12, 2)
  stock         Int         @default(0)
  attributes    Json        @default("{}")
  isDefault     Boolean     @default(false)
  sortOrder     Int         @default(0)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems     CartItem[]
  orderItems    OrderItem[]

  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  publicId  String
  alt       String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductModel3D {
  id        String  @id @default(cuid())
  productId String
  glbUrl    String
  usdzUrl   String?
  posterUrl String?
  publicId  String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ============================================================================
// Cart
// ============================================================================

model Cart {
  id        String     @id @default(cuid())
  token     String     @unique
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  couponId  String?
  coupon    Coupon?    @relation(fields: [couponId], references: [id])
  items     CartItem[]
  currency  String     @default("TRY")
  expiresAt DateTime
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([token])
  @@index([userId])
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  productId String
  variantId String
  quantity  Int
  unitPrice Decimal        @db.Decimal(12, 2)
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [productId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
}

// ============================================================================
// Orders & Payments
// ============================================================================

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  userId        String?
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  email         String
  status        OrderStatus @default(PENDING)
  currency      String      @default("TRY")
  subtotal      Decimal     @db.Decimal(12, 2)
  shippingCost  Decimal     @db.Decimal(12, 2)
  discountTotal Decimal     @default(0) @db.Decimal(12, 2)
  total         Decimal     @db.Decimal(12, 2)
  couponCode    String?

  shippingAddressId String?
  billingAddressId  String?
  shippingAddress   Address? @relation("OrderShipping", fields: [shippingAddressId], references: [id])
  billingAddress    Address? @relation("OrderBilling", fields: [billingAddressId], references: [id])

  items   OrderItem[]
  payment Payment?

  customerNote    String? @db.Text
  adminNote       String? @db.Text
  trackingNumber  String?
  trackingCarrier String?
  /**
   * Set true after stock has been re-incremented for a cancelled order. Idempotency guard.
   */
  stockRestored   Boolean @default(false)

  placedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderNumber])
  @@index([userId])
  @@index([status, placedAt])
}

model OrderItem {
  id           String         @id @default(cuid())
  orderId      String
  productId    String
  variantId    String
  nameSnapshot String
  skuSnapshot  String
  quantity     Int
  unitPrice    Decimal        @db.Decimal(12, 2)
  lineTotal    Decimal        @db.Decimal(12, 2)
  order        Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product        @relation(fields: [productId], references: [id])
  variant      ProductVariant @relation(fields: [variantId], references: [id])
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id])
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("TRY")
  reference       String?
  providerPayload Json?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model BankAccount {
  id            String  @id @default(cuid())
  bankName      String
  accountHolder String
  iban          String
  swift         String?
  currency      String  @default("TRY")
  isActive      Boolean @default(true)
  sortOrder     Int     @default(0)
}

// ============================================================================
// Promotions & Addresses
// ============================================================================

model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique
  type        CouponType
  value       Decimal    @db.Decimal(12, 2)
  minSubtotal Decimal?   @db.Decimal(12, 2)
  startsAt    DateTime?
  endsAt      DateTime?
  usageLimit  Int?
  usedCount   Int        @default(0)
  isActive    Boolean    @default(true)
  carts       Cart[]

  @@index([code])
}

model Address {
  id             String      @id @default(cuid())
  userId         String?
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  type           AddressType
  fullName       String
  line1          String
  line2          String?
  city           String
  district       String?
  postalCode     String
  country        String      @default("TR")
  phone          String?
  ordersShipping Order[]     @relation("OrderShipping")
  ordersBilling  Order[]     @relation("OrderBilling")
  createdAt      DateTime    @default(now())
}

// ============================================================================
// Store
// ============================================================================

// Inbound messages from the storefront /contact form. Persisted so the atelier
// keeps a durable queue (admin UI is a separate task). isRead drives the unread
// badge; createdAt is indexed for the default "newest first" inbox sort.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model StoreSettings {
  id                    String   @id @default("singleton")
  brandName             String   @default("efruze")
  tagline               Json // { tr: string, en: string }
  contactEmail          String
  whatsapp              String?
  instagram             String?
  defaultCurrency       String   @default("TRY")
  shippingFlatRate      Decimal  @default(0) @db.Decimal(12, 2)
  freeShippingThreshold Decimal? @db.Decimal(12, 2)

  // Editorial content — surfaced on /contact and /maison.
  addressTr          String? @db.Text
  addressEn          String? @db.Text
  hoursTr            String? @db.Text
  hoursEn            String? @db.Text
  maisonHeroImageUrl String?
  maisonIntroTr      String? @db.Text
  maisonIntroEn      String? @db.Text

  updatedAt DateTime @updatedAt
}

// ============================================================================
// Editorial — Events & Journal (admin-managed content)
// ============================================================================

enum EventKind {
  WORKSHOP
  DROP
  EXHIBITION
  VISIT
  OTHER
}

model Event {
  id          String    @id @default(cuid())
  slug        String    @unique
  date        DateTime
  kind        EventKind @default(WORKSHOP)
  imageUrl    String?
  /// Free-form price label: "₺ 1,800", "Open", "Free", "RSVP" — admin types whatever fits.
  priceText   String?
  /// Where the CTA links — internal path like "/contact" or external URL.
  ctaUrl      String    @default("/contact")
  isPublished Boolean   @default(true)
  sortOrder   Int       @default(0)
  publishedAt DateTime?

  translations EventTranslation[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([slug])
  @@index([date])
  @@index([isPublished, date])
}

model EventTranslation {
  id          String @id @default(cuid())
  eventId     String
  locale      String
  /// Short kind tag shown above the title, e.g. "Workshop · 8 seats only".
  tag         String
  title       String
  description String @db.Text
  /// Single line of event meta: time + location, e.g. "Sat, 14.06 · 14:00–17:00 · Alanya".
  meta        String
  ctaLabel    String
  event       Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, locale])
}

model JournalEntry {
  id          String    @id @default(cuid())
  slug        String    @unique
  date        DateTime
  imageUrl    String?
  featured    Boolean   @default(false)
  readMinutes Int       @default(5)
  isPublished Boolean   @default(true)
  sortOrder   Int       @default(0)
  publishedAt DateTime?

  translations JournalEntryTranslation[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([slug])
  @@index([date])
  @@index([isPublished, featured, date])
}

model JournalEntryTranslation {
  id       String       @id @default(cuid())
  entryId  String
  locale   String
  category String
  title    String
  excerpt  String       @db.Text
  body     String       @db.Text
  entry    JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, locale])
}

// ============================================================================
// Static content — FAQ, generic pages, Maison editorial sections
// ============================================================================

model FaqItem {
  id           String               @id @default(cuid())
  sortOrder    Int                  @default(0)
  isActive     Boolean              @default(true)
  translations FaqItemTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model FaqItemTranslation {
  id       String  @id @default(cuid())
  itemId   String
  locale   String
  question String  @db.Text
  answer   String  @db.Text
  item     FaqItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, locale])
}

model StaticPage {
  id           String                  @id @default(cuid())
  /// Stable slug used by the storefront to look the page up: "terms", "privacy".
  slug         String                  @unique
  isActive     Boolean                 @default(true)
  translations StaticPageTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model StaticPageTranslation {
  id     String     @id @default(cuid())
  pageId String
  locale String
  title  String
  /// Optional short disclaimer/intro rendered before the body (e.g., legal template note).
  intro  String?    @db.Text
  /// Long-form body, paragraphs separated by blank lines. Rendered with whitespace-pre-line.
  body   String     @db.Text
  page   StaticPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
}

model MaisonStep {
  id           String                  @id @default(cuid())
  sortOrder    Int                     @default(0)
  isActive     Boolean                 @default(true)
  translations MaisonStepTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model MaisonStepTranslation {
  id          String     @id @default(cuid())
  stepId      String
  locale      String
  title       String
  description String     @db.Text
  step        MaisonStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([stepId, locale])
}

model MaisonArtisan {
  id           String                     @id @default(cuid())
  sortOrder    Int                        @default(0)
  isActive     Boolean                    @default(true)
  imageUrl     String?
  translations MaisonArtisanTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model MaisonArtisanTranslation {
  id        String        @id @default(cuid())
  artisanId String
  locale    String
  name      String
  role      String
  bio       String        @db.Text
  artisan   MaisonArtisan @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@unique([artisanId, locale])
}
